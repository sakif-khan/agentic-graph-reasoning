# or specific large file formats common in training/graphs
cache/
datasets/
data/triple_index/
*.csv
*.csv.gz
*.tsv
*.parquet
*.h5

# ==========================================
# Model Checkpoints & Weights
# ==========================================
models/
checkpoints/
*.pt
*.pth
*.bin
*.safetensors
*.onnx

# ==========================================
# Logs, Profiling & Experiment Tracking
# ==========================================
temp/
*.log
wandb/
mlruns/
tensorboard/
profile_results/

# ==========================================
# OS / System Artifacts
# ==========================================
.DS_Store
Thumbs.db