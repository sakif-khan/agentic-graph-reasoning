# ==========================================
.env
.venv
env/
venv/
conda-env/
.Python

# ==========================================
# Python & Compilation Artifacts
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/

# ==========================================
# Jupyter & IDEs
# ==========================================
.ipynb_checkpoints/
.vscode/
.idea/

# ==========================================
# Data & Datasets (Prevent Repo Bloat)
# ==========================================
